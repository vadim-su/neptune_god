[configuration]
entry_symbol = "gdext_rust_init"
compatibility_minimum = "4.2"

[libraries]
linux.debug.x86_64 = "res://target/debug/libneptune_godot.so"
linux.release.x86_64 = "res://target/release/libneptune_godot.so"
windows.debug.x86_64 = "res://target/debug/neptune_godot.dll"
windows.release.x86_64 = "res://target/release/neptune_godot.dll"
macos.debug = "res://target/debug/libneptune_godot.dylib"
macos.release = "res://target/release/libneptune_godot.dylib"
